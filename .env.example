# Copy this file to `.env` for local development.
# Vite only exposes variables prefixed with `VITE_` to the client.

# Backend/API (placeholder until Task 1.1 is implemented)
# Valid values: development | staging | production
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000

# Optional per-environment defaults (used when VITE_API_BASE_URL / VITE_WS_URL are not set)
# VITE_STAGING_API_BASE_URL=https://staging-api.terra-sweep-sparkle.com/api
# VITE_STAGING_WS_URL=wss://staging-api.terra-sweep-sparkle.com
# VITE_PRODUCTION_API_BASE_URL=https://api.terra-sweep-sparkle.com/api
# VITE_PRODUCTION_WS_URL=wss://api.terra-sweep-sparkle.com

# Simulation / UI timing overrides (optional)
VITE_DEPLOY_TIMEOUT_MS=2000
VITE_RETURN_TIMEOUT_MS=3000
VITE_CLEANING_INTERVAL_MS=2000

# Battery behavior (optional)
VITE_BATTERY_LOW_THRESHOLD=20

