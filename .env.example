# Copy this file to `.env` for local development.
# Vite only exposes variables prefixed with `VITE_` to the client.

# Backend/API (placeholder until Task 1.1 is implemented)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000

# Simulation / UI timing overrides (optional)
VITE_DEPLOY_TIMEOUT_MS=2000
VITE_RETURN_TIMEOUT_MS=3000
VITE_CLEANING_INTERVAL_MS=2000

# Battery behavior (optional)
VITE_BATTERY_LOW_THRESHOLD=20

